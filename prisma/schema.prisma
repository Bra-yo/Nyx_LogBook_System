generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  password           String
  role               UserRole
  avatar             String?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  mustChangePassword Boolean            @default(false)
  phone              String?
  bio                String?
  skills             String[]           @default([])
  certificates       Json?
  socialLinks        Json?
  adminProfile       AdminProfile?
  auditLogs          AuditLog[]
  lecturerProfile    LecturerProfile?
  notifications      Notification[]
  sessions           Session[]
  studentProfile     StudentProfile?
  supervisorProfile  SupervisorProfile?
  workerProfile      WorkerProfile?

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Department {
  id            String              @id @default(cuid())
  name          String              @unique
  code          String              @unique
  description   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  adminProfiles AdminProfile[]
  lecturers     LecturerProfile[]
  Milestone     Milestone[]
  Project       Project[]
  students      StudentProfile[]
  supervisors   SupervisorProfile[]

  @@map("departments")
}

model Project {
  id              String             @id @default(cuid())
  title           String
  description     String?
  companyName     String?
  departmentId    String?
  mentorId        String?
  status          ProjectStatus      @default(ACTIVE)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  actualEndDate   DateTime?
  expectedEndDate DateTime?
  projectCode     String?            @unique
  projectName     String?
  startDate       DateTime?
  supervisorId    String?
  learners        ProjectLearner[]
  LogbookEntry    LogbookEntry[]
  milestones      Milestone[]
  projectMembers  ProjectMember[]
  department      Department?        @relation(fields: [departmentId], references: [id])
  mentor          SupervisorProfile? @relation("MentorProjects", fields: [mentorId], references: [id])
  supervisor      SupervisorProfile? @relation("SupervisorProjects", fields: [supervisorId], references: [id])
  tasks           Task[]

  @@map("projects")
}

model ProjectLearner {
  id         String         @id @default(cuid())
  projectId  String
  learnerId  String
  assignedAt DateTime       @default(now())
  learner    StudentProfile @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, learnerId])
}

model StudentProfile {
  id                     String                   @id @default(cuid())
  userId                 String                   @unique
  regNumber              String                   @unique
  departmentId           String
  supervisorId           String?
  lecturerId             String?
  year                   Int
  semester               Int
  internshipCompany      String?
  internshipStartDate    DateTime?
  internshipEndDate      DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  ProjectLearner         ProjectLearner[]
  attendanceRecords      Attendance[]
  assessments            LecturerAssessment[]
  logbookEntries         LogbookEntry[]
  Milestone              Milestone[]
  department             Department               @relation(fields: [departmentId], references: [id])
  lecturer               LecturerProfile?         @relation(fields: [lecturerId], references: [id])
  supervisor             SupervisorProfile?       @relation(fields: [supervisorId], references: [id])
  user                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  WeeklyMentorTaskReview WeeklyMentorTaskReview[]

  @@map("student_profiles")
}

model WorkerProfile {
  id                 String          @id @default(cuid())
  userId             String          @unique
  erpEmployeeId      String?
  staffNumber        String?         @unique
  firstName          String?
  middleName         String?
  lastName           String?
  fullName           String?
  email              String?
  phoneNumber        String?
  department         String?
  jobTitle           String?
  employmentStatus   String?
  nationalId         String?
  dateEmployed       DateTime?
  gender             String?
  lastSyncTime       DateTime?
  erpUpdatedAt       DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  attendanceRecords  Attendance[]
  projectMemberships ProjectMember[]
  assignedTasks      Task[]          @relation("AssignedTasks")
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerWorkLogs     TaskWorkLog[]

  @@map("worker_profiles")
}

model ProjectMember {
  id        String        @id @default(cuid())
  projectId String
  workerId  String
  joinedAt  DateTime      @default(now())
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker    WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([projectId, workerId])
  @@map("project_members")
}

model Task {
  id                String         @id @default(cuid())
  projectId         String
  assignedWorkerId  String?
  taskTitle         String
  taskDescription   String?
  priority          TaskPriority   @default(MEDIUM)
  status            TaskStatus     @default(PENDING)
  expectedStartDate DateTime?
  expectedEndDate   DateTime?
  completedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  assignedWorker    WorkerProfile? @relation("AssignedTasks", fields: [assignedWorkerId], references: [id])
  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workLogs          TaskWorkLog[]

  @@map("tasks")
}

model TaskWorkLog {
  id                   String             @id @default(cuid())
  taskId               String
  workerId             String
  workDate             DateTime
  startTime            DateTime?
  endTime              DateTime?
  hoursWorked          Float?
  progressDescription  String
  achievements         String?
  challenges           String?
  completionPercentage Int?
  supervisorComments   String?
  status               LogStatus          @default(DRAFT)
  submittedAt          DateTime?
  reviewedAt           DateTime?
  reviewedBy           String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  reviewedBySupervisor SupervisorProfile? @relation("ReviewedTaskWorkLogs", fields: [reviewedBy], references: [id])
  task                 Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  worker               WorkerProfile      @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([taskId, workerId, workDate])
  @@map("worker_work_logs")
}

model SupervisorProfile {
  id                     String                      @id @default(cuid())
  userId                 String                      @unique
  departmentId           String
  title                  String?
  company                String?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  milestoneAssessments   MilestoneMentorAssessment[]
  Milestone              Milestone[]
  officeLocations        OfficeLocation[]
  mentoredProjects       Project[]                   @relation("MentorProjects")
  supervisedProjects     Project[]                   @relation("SupervisorProjects")
  students               StudentProfile[]
  comments               SupervisorComment[]
  department             Department                  @relation(fields: [departmentId], references: [id])
  user                   User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  WeeklyMentorTaskReview WeeklyMentorTaskReview[]
  reviewedTaskWorkLogs   TaskWorkLog[]               @relation("ReviewedTaskWorkLogs")

  @@map("supervisor_profiles")
}

model LecturerProfile {
  id                   String                        @id @default(cuid())
  userId               String                        @unique
  departmentId         String
  title                String?
  office               String?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  assessments          LecturerAssessment[]
  department           Department                    @relation(fields: [departmentId], references: [id])
  user                 User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestoneAssessments MilestoneLecturerAssessment[]
  students             StudentProfile[]

  @@map("lecturer_profiles")
}

model AdminProfile {
  id           String     @id @default(cuid())
  userId       String     @unique
  departmentId String
  permissions  String[]   @default([])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model LogbookEntry {
  id              String              @id @default(cuid())
  studentId       String
  title           String
  description     String
  activities      String
  challenges      String?
  learnings       String?
  date            DateTime
  status          LogStatus           @default(DRAFT)
  attachments     String[]            @default([])
  submittedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  milestoneId     String?
  milestoneTaskId String?
  projectId       String?
  assessments     LecturerAssessment?
  milestone       Milestone?          @relation(fields: [milestoneId], references: [id])
  milestoneTask   MilestoneTask?      @relation(fields: [milestoneTaskId], references: [id])
  project         Project?            @relation(fields: [projectId], references: [id])
  student         StudentProfile      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  comments        SupervisorComment[]

  @@map("logbook_entries")
}

model SupervisorComment {
  id                    String                 @id @default(cuid())
  logbookEntryId        String
  supervisorId          String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  competencyDescription String
  competencyLabel       String
  competencyScore       Int
  optionalComment       String?
  status                SupervisorReviewStatus @default(PENDING)
  logbookEntry          LogbookEntry           @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
  supervisor            SupervisorProfile      @relation(fields: [supervisorId], references: [id])

  @@map("supervisor_comments")
}

model LecturerAssessment {
  id                   String           @id @default(cuid())
  studentId            String
  logbookEntryId       String?          @unique
  lecturerId           String
  technicalScore       Int?
  communicationScore   Int?
  professionalismScore Int?
  overallScore         Int?
  feedback             String?
  status               AssessmentStatus @default(NOT_ASSESSED)
  assessedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  lecturer             LecturerProfile  @relation(fields: [lecturerId], references: [id])
  logbookEntry         LogbookEntry?    @relation(fields: [logbookEntryId], references: [id])
  student              StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("lecturer_assessments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Attendance {
  id               String           @id @default(cuid())
  studentId        String?
  officeLocationId String
  checkInTime      DateTime
  checkOutTime     DateTime?
  checkInLat       Float
  checkInLng       Float
  checkOutLat      Float?
  checkOutLng      Float?
  status           AttendanceStatus @default(ACTIVE)
  hoursWorked      Float?
  qrCodeData       String
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  workerId         String?
  officeLocation   OfficeLocation   @relation(fields: [officeLocationId], references: [id])
  student          StudentProfile?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  worker           WorkerProfile?   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("attendance")
}

model OfficeLocation {
  id         String             @id @default(cuid())
  name       String
  address    String
  latitude   Float
  longitude  Float
  radius     Float              @default(100)
  isActive   Boolean            @default(true)
  qrCodeData String             @unique
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  mentorId   String?
  attendance Attendance[]
  mentor     SupervisorProfile? @relation(fields: [mentorId], references: [id])

  @@map("office_locations")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Milestone {
  id                 String                       @id @default(cuid())
  learnerId          String?
  title              String
  description        String?
  startDate          DateTime
  endDate            DateTime
  status             MilestoneStatus              @default(PENDING)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  departmentId       String?
  mentorId           String?
  projectId          String?
  entries            LogbookEntry[]
  lecturerAssessment MilestoneLecturerAssessment?
  mentorAssessment   MilestoneMentorAssessment?
  tasks              MilestoneTask[]
  department         Department?                  @relation(fields: [departmentId], references: [id])
  learner            StudentProfile?              @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  mentor             SupervisorProfile?           @relation(fields: [mentorId], references: [id])
  project            Project?                     @relation(fields: [projectId], references: [id])
  weeklyReviews      WeeklyMentorTaskReview[]

  @@map("milestones")
}

model MilestoneTask {
  id             String                   @id @default(cuid())
  milestoneId    String
  title          String
  description    String?
  expectedOutput String?
  dueDate        DateTime?
  status         MilestoneTaskStatus      @default(PENDING)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  entries        LogbookEntry[]
  milestone      Milestone                @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  weeklyReviews  WeeklyMentorTaskReview[]

  @@map("milestone_tasks")
}

model MilestoneMentorAssessment {
  id              String                 @id @default(cuid())
  milestoneId     String                 @unique
  mentorId        String
  competencyLevel Int
  status          SupervisorReviewStatus @default(PENDING)
  comment         String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  mentor          SupervisorProfile      @relation(fields: [mentorId], references: [id])
  milestone       Milestone              @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@map("milestone_mentor_assessments")
}

model MilestoneLecturerAssessment {
  id                   String          @id @default(cuid())
  milestoneId          String          @unique
  lecturerId           String
  technicalScore       Int?
  communicationScore   Int?
  professionalismScore Int?
  overallScore         Int?
  feedback             String?
  status               String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  lecturer             LecturerProfile @relation(fields: [lecturerId], references: [id])
  milestone            Milestone       @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@map("milestone_lecturer_assessments")
}

model WeeklyMentorTaskReview {
  id              String                 @id @default(cuid())
  milestoneId     String
  milestoneTaskId String?
  mentorId        String
  learnerId       String
  weekStartDate   DateTime
  weekEndDate     DateTime
  competencyLevel Int
  comment         String?
  status          SupervisorReviewStatus
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  learner         StudentProfile         @relation(fields: [learnerId], references: [id])
  mentor          SupervisorProfile      @relation(fields: [mentorId], references: [id])
  milestone       Milestone              @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  milestoneTask   MilestoneTask?         @relation(fields: [milestoneTaskId], references: [id])

  @@map("weekly_mentor_task_reviews")
}

enum AssessmentStatus {
  NOT_ASSESSED
  IN_PROGRESS
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  MENTOR_REVIEWED
  LECTURER_REVIEWED
  COMPLETED
}

enum LogStatus {
  PENDING
  APPROVED
  REJECTED
  DRAFT
}

enum UserRole {
  STUDENT
  SUPERVISOR
  LECTURER
  ADMIN
  WORKER
}

enum AttendanceStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SupervisorReviewStatus {
  APPROVED
  NEEDS_REVISION
  REJECTED
  PENDING
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MilestoneTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  VERIFIED
}
