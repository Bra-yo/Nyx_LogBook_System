generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String
  password          String
  role              UserRole
  avatar            String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  adminProfile      AdminProfile?
  auditLogs         AuditLog[]
  lecturerProfile   LecturerProfile?
  notifications     Notification[]
  sessions          Session[]
  studentProfile    StudentProfile?
  supervisorProfile SupervisorProfile?

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Department {
  id            String              @id @default(cuid())
  name          String              @unique
  code          String              @unique
  description   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  adminProfiles AdminProfile[]
  lecturers     LecturerProfile[]
  students      StudentProfile[]
  supervisors   SupervisorProfile[]

  @@map("departments")
}

model StudentProfile {
  id                  String               @id @default(cuid())
  userId              String               @unique
  regNumber           String               @unique
  departmentId        String
  supervisorId        String?
  lecturerId          String?
  year                Int
  semester            Int
  internshipCompany   String?
  internshipStartDate DateTime?
  internshipEndDate   DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  assessments         LecturerAssessment[]
  logbookEntries      LogbookEntry[]
  department          Department           @relation(fields: [departmentId], references: [id])
  lecturer            LecturerProfile?     @relation(fields: [lecturerId], references: [id])
  supervisor          SupervisorProfile?   @relation(fields: [supervisorId], references: [id])
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

model SupervisorProfile {
  id           String              @id @default(cuid())
  userId       String              @unique
  departmentId String
  title        String?
  company      String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  students     StudentProfile[]
  comments     SupervisorComment[]
  department   Department          @relation(fields: [departmentId], references: [id])
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("supervisor_profiles")
}

model LecturerProfile {
  id           String               @id @default(cuid())
  userId       String               @unique
  departmentId String
  title        String?
  office       String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  assessments  LecturerAssessment[]
  department   Department           @relation(fields: [departmentId], references: [id])
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  students     StudentProfile[]

  @@map("lecturer_profiles")
}

model AdminProfile {
  id           String     @id @default(cuid())
  userId       String     @unique
  departmentId String
  permissions  String[]   @default([])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model LogbookEntry {
  id          String              @id @default(cuid())
  studentId   String
  title       String
  description String
  activities  String
  challenges  String?
  learnings   String?
  date        DateTime
  status      LogStatus           @default(DRAFT)
  attachments String[]            @default([])
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  assessments LecturerAssessment?
  student     StudentProfile      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  comments    SupervisorComment[]

  @@map("logbook_entries")
}

model SupervisorComment {
  id             String            @id @default(cuid())
  logbookEntryId String
  supervisorId   String
  comment        String
  rating         Int?
  approved       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  logbookEntry   LogbookEntry      @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
  supervisor     SupervisorProfile @relation(fields: [supervisorId], references: [id])

  @@map("supervisor_comments")
}

model LecturerAssessment {
  id                   String           @id @default(cuid())
  studentId            String
  logbookEntryId       String?          @unique
  lecturerId           String
  technicalScore       Int?
  communicationScore   Int?
  professionalismScore Int?
  overallScore         Int?
  feedback             String?
  status               AssessmentStatus @default(NOT_ASSESSED)
  assessedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  lecturer             LecturerProfile  @relation(fields: [lecturerId], references: [id])
  logbookEntry         LogbookEntry?    @relation(fields: [logbookEntryId], references: [id])
  student              StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("lecturer_assessments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum AssessmentStatus {
  NOT_ASSESSED
  IN_PROGRESS
  COMPLETED
}

enum LogStatus {
  PENDING
  APPROVED
  REJECTED
  DRAFT
}

enum UserRole {
  STUDENT
  SUPERVISOR
  LECTURER
  ADMIN
}
